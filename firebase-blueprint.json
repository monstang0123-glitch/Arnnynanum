{
  "entities": {
    "Like": {
      "title": "Book Like",
      "description": "A record of a user liking a book.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "bookId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "bookId", "createdAt"]
    },
    "Book": {
      "title": "Book Recommendation",
      "description": "A book shared by a community member.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the book"
        },
        "author": {
          "type": "string",
          "description": "Author of the book"
        },
        "genre": {
          "type": "string",
          "description": "Genre/Category of the book"
        },
        "description": {
          "type": "string",
          "description": "Reason for recommendation or book summary"
        },
        "coverUrl": {
          "type": "string",
          "description": "URL to the book cover image"
        },
        "addedBy": {
          "type": "string",
          "description": "UID of the user who added the recommendation"
        },
        "addedByName": {
          "type": "string",
          "description": "Display name of the user"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the book was added"
        },
        "commentCount": {
          "type": "number",
          "description": "Total number of comments"
        }
      },
      "required": ["title", "author", "genre", "addedBy", "createdAt"]
    },
    "Comment": {
      "title": "Book Comment",
      "description": "A comment left by a user on a book recommendation.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "text", "createdAt"]
    }
  },
  "firestore": {
    "books": {
      "schema": "Book",
      "description": "Collection of community book recommendations"
    },
    "likes": {
      "schema": "Like",
      "description": "Relational collection tracking user likes on books"
    },
    "books/{bookId}/comments": {
      "schema": "Comment",
      "description": "Subcollection of comments for a specific book"
    }
  }
}
