rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(existingData) {
      return isSignedIn() && existingData.addedBy == request.auth.uid;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidBook(data, isUpdate) {
      return data.keys().hasAll(['title', 'author', 'genre', 'addedBy', 'createdAt'])
        && data.title is string && data.title.size() <= 200
        && data.author is string && data.author.size() <= 100
        && data.genre is string && data.genre.size() <= 50
        && (data.description == null || (data.description is string && data.description.size() <= 1000))
        && (data.coverUrl == null || (data.coverUrl is string && data.coverUrl.size() <= 1500000))
        && data.addedBy == request.auth.uid
        && (isUpdate || data.createdAt == request.time);
    }

    // --- Collections ---

    match /books/{bookId} {
      // Anyone can see recommendations
      allow get: if true;
      allow list: if true; // The UI will handle filtering/searching but anyone can browse
      
      allow create: if isSignedIn() && isValidBook(incoming(), false);
      allow delete: if isOwner(existing());
      allow update: if isOwner(existing()) 
        && isValidBook(incoming(), true)
        && incoming().addedBy == existing().addedBy
        && incoming().createdAt == existing().createdAt;
    }

    match /likes/{likeId} {
      // likeId should be userId_bookId to ensure uniqueness
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && incoming().userId == request.auth.uid
        && incoming().bookId is string
        && incoming().createdAt == request.time
        && exists(/databases/$(database)/documents/books/$(incoming().bookId));
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      
      // Allow update just in case setDoc hits an existing doc, 
      // though handleToggleLike logic tries to avoid it.
      allow update: if isSignedIn() 
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().bookId == existing().bookId
        && incoming().createdAt == existing().createdAt;
    }
  }
}
